generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id          Int        @id @default(autoincrement())
  uidFirebase String     @unique @map("uid_firebase")
  fullName    String     @map("full_name")
  email       String     @unique
  role        Role       @default(teacher)
  addressId   Int?       @map("address_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  status      UserStatus @default(ATIVO)
  address     Address?   @relation(fields: [addressId], references: [id])
  classes     Class[]    @relation("ClassTeacher")

  @@map("user")
}

model Student {
  id                  Int               @id @default(autoincrement())
  addressId           Int?              @map("address_id")
  fullName            String            @map("full_name")
  dateOfBirth         DateTime?         @map("date_of_birth") @db.Date
  registrationNumber  String            @unique @map("registration_number")
  enrollmentDate      DateTime          @default(now()) @map("enrollment_date") @db.Date
  disenrollmentDate   DateTime?         @map("disenrollment_date") @db.Date
  status              StudentStatus     @default(ATIVO)
  levelId             Int?              @map("level_id")
  socialName          String?           @map("social_name")
  race                Race?
  schoolName          String?           @map("school_name")
  schoolShift         String?           @map("school_shift")
  schoolYear          SchoolYear?       @map("school_year")
  socialPrograms      SocialProgram?    @map("social_programs")
  gender              Gender?
  employmentStatus    EmploymentStatus? @map("employment_status")
  gradeGap            Boolean?          @map("grade_gap") // defasagem escolar

  address            Address?           @relation(fields: [addressId], references: [id], onDelete: Cascade)
  level              Level?             @relation("LevelRelation",fields: [levelId], references: [id])
  family             FamilyMember[]     @relation("StudentFamily")
  frequencies        Frequency[]        @relation("StudentFrequency")
  classes            Enrollment[]
  answers            Answer[]           @relation("StudentAnswers")
  docs               Document[]              @relation("StudentDocs")
  @@map("student")
}

model Address {
  id            Int             @id @default(autoincrement())
  cep           String          @db.VarChar(9)
  street        String
  number        String?         @db.VarChar(10)
  complement    String?
  neighborhood  String
  city          String
  state         String          @db.VarChar(2)

  users         User[]
  students      Student[]
  familyMembers FamilyMember[]  @relation("FamilyAddress")

  @@map("address")
}

model Class {
  id          Int       @id @default(autoincrement())
  name        String
  activityId  Int       @map("activity_id")
  levelId     Int       @map("level_id")
  state       ClassState
  teacher     User[]    @relation("ClassTeacher")
  activity    Activity  @relation(fields: [activityId], references: [id])
  level       Level     @relation(fields: [levelId], references: [id])
  frequencies Frequency[]
  students    Enrollment[]
  isRecurrent Boolean   @default(true) @map("is_recurrent")
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date")   @db.Date
  startTime   DateTime  @map("start_time") @db.Time
  endTime     DateTime  @map("end_time")   @db.Time
  schedules   ClassSchedule[]
  @@map("class")
}
model ClassSchedule {
  id        Int       @id @default(autoincrement())
  classId   Int       @map("class_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  @@unique([classId, dayOfWeek])
  @@index([classId])
  @@map("class_schedule")
}

model Frequency {
  id        Int               @id @default(autoincrement())
  studentId Int               @map("id_student")
  classId   Int?              @map("id_class")
  date      DateTime          @db.Date
  status    FrequencyStatus   @default(PRESENTE)
  notes     NoteTypes?

  student Student @relation("StudentFrequency",fields: [studentId], references: [id])
  class   Class?   @relation(fields: [classId], references: [id])

  @@map("frequency")
}

model FamilyMember {
  id                Int               @id @default(autoincrement())
  addressId         Int?               @map("address_id")
  fullName          String            @map("full_name")
  relationship      String
  phoneNumber       String            @map("phone_number")
  nis               String?           
  registrationNumber  String           @map("registration_number")
  email             String?
  socialName        String?           @map("social_name")
  race              Race?
  gender            Gender?
  educationLevel    EducationLevel?   @map("education_level")
  dateOfBirth       DateTime         @map("date_of_birth") @db.Date
  socialPrograms    SocialProgram?    @map("social_programs")
  employmentStatus  EmploymentStatus? @map("employment_status")
  student           Student[]         @relation("StudentFamily")
  address           Address?          @relation("FamilyAddress", fields: [addressId], references: [id], onDelete: Cascade)
  @@map("family_member")
}

model Level {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?

  students Student[]    @relation("LevelRelation")
  classes  Class[]

  @@map("level")
}

model Activity {
  id   Int    @id @default(autoincrement())
  name String @unique

  classes Class[]

  @@map("activity")
}

// Tabela de junção para a relação Muitos-para-Muitos entre Student e Class
model Enrollment {
  id             Int       @id @default(autoincrement())
  studentId      Int       @map("id_student")
  classId        Int       @map("id_class")
  enrollmentDate DateTime  @default(now()) @map("enrollment_date")
  endDate        DateTime? @map("end_date") 

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
  @@map("enrollment")
}
model Question {
  id         Int      @id @default(autoincrement())
  formId     Int      @map("form_id")
  statement  String
  isRequired Boolean? @default(false) @map("is_required")
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers    Answer[] @relation("AnswersQuestions")
  @@map("question")
}

model Answer {
  id             Int      @id @default(autoincrement())
  submissionDate DateTime @default(now()) @map("submission_date") @db.Date
  questionId     Int      @map("question_id")
  studentId      Int      @map("student_id")
  content        String

  question Question @relation("AnswersQuestions", fields: [questionId], references: [id], onDelete: Cascade)
  student  Student  @relation("StudentAnswers", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("answer")
}

model Form {
  id             Int      @id @default(autoincrement())
  submissionDate DateTime @default(now()) @map("submission_date") @db.Date
  type           FormType
  title          String
  questions      Question[]
  @@map("form")
}

model Document {
  id           String    @id
  studentId    Int
  originalName String
  storagePath  String    @unique
  contentType  String
  description  String
  createdAt    DateTime  @default(now())
  status       FileStatus @default(PENDING)
  student      Student   @relation("StudentDocs", fields: [studentId], references: [id])

  @@index([studentId])
  @@map("doc")
}
enum FormType {
  PSICOLOGIA
  SOCIAL
}
enum UserStatus {
  ATIVO
  INATIVO
}
enum StudentStatus {
  ATIVO
  INATIVO
}
enum FrequencyStatus {
  PRESENTE
  AUSENTE
}

enum ClassState {
  ATIVA
  INATIVA
}

enum Race {
  BRANCA
  PRETA
  PARDA
  AMARELA
  INDIGENA
  NA
}

enum Gender {
  MASCULINO
  FEMININO
  HOMEM_TRANS
  MULHER_TRANS
  TRAVESTI
  NAO_BINARIO
  OUTRO
}

enum SocialProgram {
  BOLSA_FAMILIA
  BPC_LOAS
  TARIFA_SOCIAL_ENERGIA
  AUXILIO_GAS
  PROGRAMA_ESTADUAL
  PROGRAMA_MUNICIPAL_VIA_CRAS
}

enum EmploymentStatus {
  ESTUDANTE
  EMPREGADO
  DESEMPREGADO
  ESTAGIARIO
  APRENDIZ
  AUTONOMO
  OUTRO
}

enum SchoolYear {
  EDUCACAO_INFANTIL
  FUNDAMENTAL_1
  FUNDAMENTAL_2
  FUNDAMENTAL_3
  FUNDAMENTAL_4
  FUNDAMENTAL_5
  FUNDAMENTAL_6
  FUNDAMENTAL_7
  FUNDAMENTAL_8
  FUNDAMENTAL_9
  ENSINO_MEDIO_1
  ENSINO_MEDIO_2
  ENSINO_MEDIO_3
  EJA
}

enum EducationLevel {
  NENHUM
  ALFABETIZADO
  FUNDAMENTAL_INCOMPLETO
  FUNDAMENTAL_COMPLETO
  ENSINO_MEDIO_INCOMPLETO
  ENSINO_MEDIO_COMPLETO
  SUPERIOR_INCOMPLETO
  SUPERIOR_COMPLETO
  POS_GRADUACAO
}

enum NoteTypes {
  ATESTADO_MEDICO
  SEM_JUSTIFICATIVA
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum Role {
  admin
  manager
  teacher
  psychologist
  psychology_intern
  social_worker
  social_work_intern
}
enum FileStatus {
  PENDING
  COMPLETED
  FAILED
}
model ExampleEntity {
  id        String   @id
  name      String   
  email     String   @unique
  birthDate DateTime
}
