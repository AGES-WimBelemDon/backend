{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",              
      "request": "launch",         
      "name": "Iniciar programa",  
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/main.ts"  
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Anexar ao processo",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
